name = "reckoner-bungie"
main = "index.js"
compatibility_date = "2024-11-01"

# Public var — comma-separated allowlist of site origins.
[vars]
ALLOWED_ORIGIN = "https://solrooster.github.io,http://localhost:5175"

# Secrets are NOT stored here. Set them with:
#   wrangler secret put BUNGIE_API_KEY
#   wrangler secret put BUNGIE_CLIENT_ID
#   wrangler secret put BUNGIE_CLIENT_SECRET
# (or add them in the Cloudflare dashboard under Settings > Variables)
